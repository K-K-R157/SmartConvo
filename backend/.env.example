# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=5001

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/smartconvo
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/smartconvo
MONGO_URI=mongodb://localhost:27017/smartconvo

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Any random long string. Used to sign auth tokens.
# Generate one at: https://www.uuidgenerator.net/
JWT_SECRET=your_jwt_secret_here

# ─── Stream Chat & Video (HD Call) ──────────────────────────────────────────────
# Get FREE from: https://getstream.io/dashboard/
# Steps: Sign up → Create App → Copy "Key" and "Secret"
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# ─── Gemini AI (Smart Replies + Translation) ────────────────────────────────────
# Get FREE from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── Cloudinary (File/Image Uploads) ────────────────────────────────────────────
# Get FREE from: https://cloudinary.com/console
# Steps: Sign up → Dashboard → Copy cloud name, API key, API secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
